# Required: Gateway authentication token (generate a long random string)
OPENCLAW_GATEWAY_TOKEN=

# Ollama Configuration
# Railway internal URL — set this to the Ollama service's private networking URL
# Format: http://<ollama-service-name>.railway.internal:11434
OLLAMA_HOST=http://ollama.railway.internal:11434

# Optional: Pre-pull a model on startup (e.g., llama3, mistral, codellama)
OLLAMA_MODEL=llama3

# Optional: Messaging integrations
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=

# Port (Railway sets this automatically)
PORT=18789
